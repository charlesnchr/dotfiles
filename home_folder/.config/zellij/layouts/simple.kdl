// Simple layout without bookmark bar
// Use this if you don't want the bookmark bar visible all the time

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="zsh" focus=true {
        pane
    }
}

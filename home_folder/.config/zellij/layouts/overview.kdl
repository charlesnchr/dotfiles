// Virtual session overview layout
// Shows all sessions in a grid view

layout {
    tab name="overview" focus=true {
        pane split_direction="vertical" {
            pane split_direction="horizontal" {
                pane {
                    command "zellij-session-overview"
                    args "1"
                }
                pane {
                    command "zellij-session-overview"
                    args "2"
                }
            }
            pane split_direction="horizontal" {
                pane {
                    command "zellij-session-overview"
                    args "3"
                }
                pane {
                    command "zellij-session-overview"
                    args "4"
                }
            }
        }
        pane split_direction="horizontal" {
            pane {
                command "zellij-session-overview"
                args "5"
            }
            pane name="claude" focus=true {
                // Shared Claude pane
                // Use this for running claude-code across all your sessions
            }
        }
    }
}

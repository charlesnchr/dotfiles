# Ghostty configuration for Zellij integration

# Shell integration
shell-integration = true
shell-integration-features = cursor,sudo,title

# Window settings
window-decoration = true
window-padding-x = 4
window-padding-y = 4

# Font settings (adjust to your preference)
font-family = "JetBrainsMono Nerd Font"
font-size = 12

# Theme - Gruvbox Dark (matching Zellij)
background = 282828
foreground = ebdbb2
cursor-color = ebdbb2

# Gruvbox Dark colors
palette = 0=#282828
palette = 1=#cc241d
palette = 2=#98971a
palette = 3=#d79921
palette = 4=#458588
palette = 5=#b16286
palette = 6=#689d6a
palette = 7=#a89984
palette = 8=#928374
palette = 9=#fb4934
palette = 10=#b8bb26
palette = 11=#fabd2f
palette = 12=#83a598
palette = 13=#d3869b
palette = 14=#8ec07c
palette = 15=#ebdbb2

# Terminal features
term = xterm-256color
copy-on-select = true
mouse-hide-while-typing = true

# Clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false

# Performance
gpu-renderer = auto

# Keybindings for Zellij compatibility
# Pass through Ctrl+a and Ctrl+q to Zellij
keybind = ctrl+a=ignore
keybind = ctrl+q=ignore

# Allow Alt key combinations for quick session switching
keybind = alt+1=ignore
keybind = alt+2=ignore
keybind = alt+3=ignore
keybind = alt+4=ignore
keybind = alt+5=ignore

# Alt+a should send Escape+a
keybind = alt+a=text:\x1ba

# Scrollback
scrollback-limit = 100000

# Initial command - launch Zellij
# Uncomment the next line to auto-start Zellij
# command = zellij

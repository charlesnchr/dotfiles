// Development layout with side-by-side editor and terminal
// Good for active development with tests running

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }

    // Tab 1: Main development view - editor + terminal side by side
    tab name="dev" focus=true {
        pane split_direction="vertical" {
            pane command="zsh" {
                args "-ic" "nvim"
                size "60%"
            }
            pane split_direction="horizontal" {
                pane size="50%"  // General terminal
                pane command="zsh" {
                    args "-c" "echo 'Test runner - run your tests here'"
                }
            }
        }
    }

    // Tab 2: File browser
    tab name="files" {
        pane command="zsh" {
            args "-ic" "ranger"
        }
    }

    // Tab 3: Git
    tab name="git" {
        pane command="zsh" {
            args "-ic" "lazygit || git status"
        }
    }

    // Tab 4: Claude
    tab name="claude" {
        pane command="zsh" {
            args "-ic" "ccv -y"
        }
    }

    // Tab 5: Logs
    tab name="log" {
        pane
    }
}

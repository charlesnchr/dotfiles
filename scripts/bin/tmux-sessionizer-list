#!/opt/homebrew/bin/bash

# Outputs the full sessionizer list (for fzf ctrl-r reload)

current_session=$(tmux display-message -p '#{session_name}' 2>/dev/null)

while IFS= read -r session; do
    if [[ -n $session && "$session" != "$current_session" ]]; then
        echo "▶️ $session"
    fi
done < <(tmux list-sessions -F "#{session_last_attached} #{session_name}" 2>/dev/null | sort -rn | awk '{print $2}')

zoxide query -l 2>/dev/null | awk -F/ '{print $NF "    " $0}'

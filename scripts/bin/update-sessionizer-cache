#!/opt/homebrew/bin/bash

# This creates a complete cache for tmux-sessionizer with all directories.
all_dirs_cache="$HOME/.cache/tmux-sessionizer-all-dirs"
maxdepth="${TMUX_SESSIONIZER_MAXDEPTH:-2}"

# Discover git repos under these roots.
repo_roots=(
    ~/1private
    ~/dotfiles
    ~/qmk_firmware
    ~/0main
    ~/extensions
)

content_dirs=(
    ~/1private
    ~/dotfiles
    ~/qmk_firmware
    ~/0main
    ~/extensions
)

fixed_dirs=(
    ~/1private
    ~/qmk_firmware
    ~/dotfiles
    ~/0main
    ~/extensions
)

declare -a git_repos=()
declare -A repo_seen

for root in "${repo_roots[@]}"; do
    root_expanded="${root/#\~/$HOME}"
    if [[ ! -d $root_expanded ]]; then
        continue
    fi

    if [[ -d "$root_expanded/.git" && -z ${repo_seen["$root_expanded"]} ]]; then
        git_repos+=("$root_expanded")
        repo_seen["$root_expanded"]=1
    fi

    while IFS= read -r gitdir; do
        candidate=$(dirname "$gitdir")
        candidate=${candidate%/}
        if [[ -z ${repo_seen["$candidate"]} ]]; then
            git_repos+=("$candidate")
            repo_seen["$candidate"]=1
        fi
    done < <(find -L "$root_expanded" -mindepth 1 -maxdepth "$maxdepth" -type d -name .git 2>/dev/null)
done

mkdir -p "$(dirname "$all_dirs_cache")"
> "$all_dirs_cache"
rm -f "$HOME/.cache/git-branches-cache" "$HOME/.cache/tmux-sessionizer-branches"

declare -A seen_paths

for repo in "${git_repos[@]}"; do
    folder=$(basename "$repo")
    if [[ -n $folder ]]; then
        echo "$folder    $repo" >> "$all_dirs_cache"
        seen_paths["$repo"]=1
    fi
done

for dir in "${fixed_dirs[@]}"; do
    dir_expanded="${dir/#\~/$HOME}"
    if [[ -d $dir_expanded && -z ${seen_paths["$dir_expanded"]} ]]; then
        echo "$(basename "$dir_expanded")    $dir_expanded" >> "$all_dirs_cache"
        seen_paths["$dir_expanded"]=1
    fi
done

for dir in "${content_dirs[@]}"; do
    dir_expanded="${dir/#\~/$HOME}"
    if [[ -d $dir_expanded ]]; then
        while IFS= read -r subdir; do
            subdir=${subdir%/}
            if [[ -z ${seen_paths["$subdir"]} ]]; then
                echo "$(basename "$subdir")    $subdir" >> "$all_dirs_cache"
                seen_paths["$subdir"]=1
            fi
        done < <(find -L "$dir_expanded" -mindepth 1 -maxdepth 1 -type d -not -path '*/.*' 2>/dev/null)
    fi
done

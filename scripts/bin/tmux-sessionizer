#!/opt/homebrew/bin/bash

# If we're in a window named "sessionizer", close it (toggle behavior)
current_window=$(tmux display-message -p '#{window_name}' 2>/dev/null)
if [[ "$current_window" == "sessionizer" ]]; then
    tmux kill-window
    exit 0
fi

# Name this window "sessionizer" for toggle functionality
tmux rename-window "sessionizer" 2>/dev/null

# Load all directories from cache - no find commands!
all_dirs_cache="$HOME/.cache/tmux-sessionizer-all-dirs"

# Get current session to exclude it
current_session=$(tmux display-message -p '#{session_name}' 2>/dev/null)

# Get a list of running tmux sessions sorted by last activity
tmux_sessions_raw=$(tmux list-sessions -F "#{session_last_attached} #{session_name}" 2>/dev/null | sort -rn | awk '{print $2}')
tmux_sessions=()
declare -A active_sessions
while IFS= read -r session; do
    if [[ -n $session ]]; then
        active_sessions["$session"]=1
        [[ "$session" == "$current_session" ]] && continue
        tmux_sessions+=("▶️ $session")
    fi
done <<< "$tmux_sessions_raw"

# Load directories from cache, filtering out ones with active sessions
selected_dirs=()
if [[ -f $all_dirs_cache ]]; then
    while IFS= read -r line; do
        folder=${line%% *}
        session_name=${folder//./_}
        [[ -z ${active_sessions[$session_name]} ]] && selected_dirs+=("$line")
    done < "$all_dirs_cache"
fi

# Use the filtered paths array and tmux sessions in fzf
if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(printf "%s\n" "${tmux_sessions[@]}" "${selected_dirs[@]}" | fzf \
        --height=80% \
        --margin=5%,5% \
        --preview 'path=$(echo {} | awk "{print \$NF}"); tmux capture-pane -pt "$path" -S -500 2>/dev/null || /bin/ls -la "$path"' \
        --prompt="projects > " \
        --delimiter='  ' \
        --with-nth=1,2 \
        --ansi \
        --color='dark,bg+:#3a3a3a,fg+:#ffffff,hl:#5fd7ff,hl+:#5fd7ff' \
        --header='[name]  [path/type]  (ctrl-r: refresh)' \
        --bind='ctrl-r:reload(~/bin/tmux-sessionizer-list)'
    )
fi

if [[ -z $selected ]]; then
    exit 0
fi

if [[ $selected == ▶️* ]]; then
    selected_name=$(echo "$selected" | awk '{print $2}')
    selected_path=$selected_name
else
    selected_path=$(echo "$selected" | awk '{print $NF}')

    if [[ ! -d $selected_path ]]; then
        selected_path=$selected
    fi

    selected_name=$(basename "$selected_path" | tr . _)
fi

tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    if [[ -d $selected_path ]]; then
        tmux new-session -s $selected_name -c $selected_path
    else
        tmux attach-session -t $selected_path
    fi
    exit 0
fi

if ! tmux has-session -t=$selected_name 2>/dev/null; then
    if [[ -d $selected_path ]]; then
        tmux new-session -ds $selected_name -c $selected_path
        tmux switch-client -t $selected_name
    else
        tmux new-session -ds $selected_name
        tmux switch-client -t $selected_name
    fi
else
    tmux switch-client -t $selected_name
fi

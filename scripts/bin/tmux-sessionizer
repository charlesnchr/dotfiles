#!/opt/homebrew/bin/bash

# If we're in a window named "sessionizer", close it (toggle behavior)
current_window=$(tmux display-message -p '#{window_name}' 2>/dev/null)
if [[ "$current_window" == "sessionizer" ]]; then
    tmux kill-window
    exit 0
fi

# Name this window "sessionizer" for toggle functionality
tmux rename-window "sessionizer" 2>/dev/null

current_session=$(tmux display-message -p '#{session_name}' 2>/dev/null)

# Build active sessions set for filtering
declare -A active_sessions
tmux_sessions=()
while IFS= read -r session; do
    if [[ -n $session ]]; then
        active_sessions["$session"]=1
        [[ "$session" != "$current_session" ]] && tmux_sessions+=("▶️ $session")
    fi
done < <(tmux list-sessions -F "#{session_last_attached} #{session_name}" 2>/dev/null | sort -rn | awk '{print $2}')

# fzf: enter = new tab, tab = new session, ctrl-r = refresh
if [[ $# -eq 1 ]]; then
    selected=$1
    key=""
else
    result=$( {
        printf "%s\n" "${tmux_sessions[@]}"
        zoxide query -l 2>/dev/null | awk -F/ '{print $NF "    " $0}'
    } | fzf \
        --height=80% \
        --margin=5%,5% \
        --preview 'path=$(echo {} | awk "{print \$NF}"); tmux capture-pane -pt "$path" -S -500 2>/dev/null || /bin/ls -la "$path"' \
        --prompt="projects > " \
        --delimiter='  ' \
        --with-nth=1,2 \
        --ansi \
        --color='dark,bg+:#3a3a3a,fg+:#ffffff,hl:#5fd7ff,hl+:#5fd7ff' \
        --header='enter: new tab | tab: new session | ctrl-r: refresh' \
        --expect='tab' \
        --bind='ctrl-r:reload(~/bin/tmux-sessionizer-list)'
    )
    key=$(head -1 <<< "$result")
    selected=$(tail -n +2 <<< "$result")
fi

if [[ -z $selected ]]; then
    exit 0
fi

# Parse selection
if [[ $selected == ▶️* ]]; then
    selected_name=$(echo "$selected" | awk '{print $2}')
    selected_path=$selected_name
else
    selected_path=$(echo "$selected" | awk '{print $NF}')
    [[ ! -d $selected_path ]] && selected_path=$selected
    selected_name=$(basename "$selected_path" | tr . _)
fi

# Existing session: just switch to it
if [[ $selected == ▶️* ]] || tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux switch-client -t "$selected_name"
    exit 0
fi

# tab: create a new session
if [[ $key == "tab" ]]; then
    if [[ -d $selected_path ]]; then
        tmux new-session -ds "$selected_name" -c "$selected_path"
    else
        tmux new-session -ds "$selected_name"
    fi
    tmux switch-client -t "$selected_name"
else
    # enter: new window (tab) in current session
    if [[ -d $selected_path ]]; then
        tmux new-window -n "$selected_name" -c "$selected_path"
    else
        tmux new-window -n "$selected_name"
    fi
fi

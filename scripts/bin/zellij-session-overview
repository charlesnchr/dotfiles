#!/usr/bin/env bash

# Display overview of a session
# Usage: zellij-session-overview <bookmark-index>

index=$1
bookmark_file="$HOME/.cache/zellij-session-bookmarks"

if [[ -z $index ]]; then
    echo "No session index specified"
    sleep infinity
    exit 1
fi

# Load bookmarks
declare -A bookmarks
if [[ -f $bookmark_file ]]; then
    while IFS='=' read -r idx session; do
        [[ -n $idx ]] && bookmarks[$idx]="$session"
    done < "$bookmark_file"
fi

session_name="${bookmarks[$index]}"

if [[ -z $session_name ]]; then
    echo "Slot $index: No session bookmarked"
    echo ""
    echo "Press Ctrl+a B $index to bookmark a session here"
    sleep infinity
    exit 0
fi

# Check if session exists
session_exists=$(zellij list-sessions 2>/dev/null | grep -w "$session_name")

if [[ -z $session_exists ]]; then
    echo "Slot $index: $session_name (not running)"
    sleep infinity
    exit 0
fi

# Show live session info with continuous updates
clear

# Function to display session info
show_session_info() {
    clear
    echo "═══════════════════════════════════════"
    echo "  📍 Slot $index: $session_name"
    echo "═══════════════════════════════════════"
    echo ""

    # Show session status
    if zellij list-sessions 2>/dev/null | grep -q "(current).*$session_name"; then
        echo "🟢 Status: Active (you're here)"
    else
        echo "🟡 Status: Running"
    fi
    echo ""

    # Show working directory if available
    if [[ -d ~/.local/share/zellij/sessions/$session_name ]]; then
        echo "📂 Session exists"
    fi
    echo ""

    # Show quick actions
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  Alt+$index  → Switch to this session"
    echo "  Ctrl+a B $index → Rebookmark this slot"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Show last update time
    echo "Last updated: $(date '+%H:%M:%S')"
}

# Update every 2 seconds
while true; do
    show_session_info
    sleep 2
done

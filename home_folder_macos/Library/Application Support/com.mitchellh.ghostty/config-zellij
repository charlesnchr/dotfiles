# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

keybind = cmd+p=toggle_command_palette
keybind = ctrl+m=text:\r
keybind = cmd+b=esc:b
keybind = cmd+f=esc:f
keybind = cmd+d=esc:d
keybind = cmd+a=esc:a
keybind = cmd+e=esc:e
keybind = global:opt+t=toggle_quick_terminal

# theme = dark:Catppuccin Frappe,light:Catppuccin Latte
theme = dark:Spacegray Bright,light:Rose Pine Dawn

macos-option-as-alt = right

macos-titlebar-style = hidden

confirm-close-surface=false

# Split management
keybind = cmd+s=new_split:right
keybind = cmd+shift+apostrophe=new_split:down

# Navigating between splits - use goto_split, not focus_split
# Alternative: vim-style navigation
keybind = cmd+h=goto_split:left

# Hide window alternative since cmd+h is used for split navigation
keybind = cmd+shift+h=toggle_visibility
keybind = cmd+l=goto_split:right
keybind = cmd+k=goto_split:up
keybind = cmd+j=goto_split:down

# Equalize splits
keybind = ctrl+space>equal=equalize_splits

# Resize splits (hold down for repeated resizing)
keybind = cmd+u=resize_split:left,20
keybind = cmd+i=resize_split:up,20
keybind = cmd+shift+o=resize_split:down,20
keybind = cmd+shift+p=resize_split:right,20

# Zellij tab switching - send Alt+digit (ESC + digit)
keybind = cmd+digit_1=text:\x1b1
keybind = cmd+digit_2=text:\x1b2
keybind = cmd+digit_3=text:\x1b3
keybind = cmd+digit_4=text:\x1b4
keybind = cmd+digit_5=text:\x1b5
keybind = cmd+digit_6=text:\x1b6
keybind = cmd+digit_7=text:\x1b7
keybind = cmd+digit_8=text:\x1b8
keybind = cmd+digit_9=text:\x1b9

# Zellij tab navigation - send Alt+[ and Alt+]
keybind = cmd+left_bracket=text:\x1b[
keybind = cmd+right_bracket=text:\x1b]

# Zellij sessionizer - send Ctrl+a then o
keybind = cmd+o=text:\x01o

# For claude code
keybind = shift+enter=text:\n

# Toggle pane zoom (prefix + z)
# keybind = cmd+z=text:\x01\x7a

# Alt+digit for zellij tab switching (Option key)
keybind = opt+digit_1=text:\x1b1
keybind = opt+digit_2=text:\x1b2
keybind = opt+digit_3=text:\x1b3
keybind = opt+digit_4=text:\x1b4
keybind = opt+digit_5=text:\x1b5
keybind = opt+digit_6=text:\x1b6
keybind = opt+digit_7=text:\x1b7
keybind = opt+digit_8=text:\x1b8
keybind = opt+digit_9=text:\x1b9
